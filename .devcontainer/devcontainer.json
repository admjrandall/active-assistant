{
  // GitHub Codespaces configuration
  // Opens a fully-configured Node dev environment in your browser —
  // no local install required. Access via:
  //   github.com → your repo → Code → Codespaces → New codespace
  "name": "Active Assistant",

  // Use the official Node.js devcontainer image (LTS)
  "image": "mcr.microsoft.com/devcontainers/node:lts",

  // Automatically install dependencies when the Codespace starts
  "postCreateCommand": "npm install",

  // Forward Vite's default port so you can preview the app in the browser
  "forwardPorts": [5173],
  "portsAttributes": {
    "5173": {
      "label": "Vite Dev Server",
      "onAutoForward": "openPreview"
    }
  },

  // VS Code settings and extensions pre-installed in the Codespace
  "customizations": {
    "vscode": {
      "settings": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "editor.tabSize": 2,
        "files.eol": "\n"
      },
      "extensions": [
        "esbenp.prettier-vscode",
        "dbaeumer.vscode-eslint",
        "bradlc.vscode-tailwindcss",
        "ms-vscode.vscode-typescript-next"
      ]
    }
  }
}
